<script>
function downloadReport(){
  var html = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
  var blob = new Blob([html], {type: 'text/html;charset=utf-8'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = '{{ header.name }}_보장분석리포트.html';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function showShareToast(msg){
  var t = document.getElementById('shareToast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 3200);
}

async function shareReport(){
  var btn = document.getElementById('shareBtn');
  if (!btn) return;
  var url = btn.dataset.url;
  var title = btn.dataset.title;
  if (!url) {
    try {
      var resp = await fetch('/reports/' + btn.dataset.reportId + '/share', {
        method: 'POST',
        headers: {'Accept': 'application/json'},
      });
      var data = await resp.json();
      url = data.url;
      btn.dataset.url = url;
    } catch (e) {
      showShareToast('공유 링크 생성에 실패했습니다.');
      return;
    }
  }
  if (window.Kakao && window.Kakao.isInitialized && window.Kakao.isInitialized()) {
    window.Kakao.Share.sendDefault({
      objectType: 'text',
      text: title,
      link: {mobileWebUrl: url, webUrl: url},
    });
    return;
  }
  if (navigator.share) {
    try {
      await navigator.share({title: title, url: url});
      return;
    } catch (e) {
      return; // 사용자가 공유를 취소한 경우 등 — 별다른 처리 없이 종료
    }
  }
  try {
    await navigator.clipboard.writeText(url);
    showShareToast('링크가 복사되었습니다. 카카오톡에 붙여넣어 보내주세요.');
  } catch (e) {
    window.prompt('아래 링크를 복사해서 카카오톡으로 보내주세요.', url);
  }
}

document.getElementById('shareBtn')?.addEventListener('click', shareReport);

(function(){
  var fab = document.getElementById('chatFab');
  if (!fab) return;
  var panel = document.getElementById('chatPanel');
  var body = document.getElementById('chatBody');
  var empty = document.getElementById('chatEmpty');
  var input = document.getElementById('chatInput');
  var sendBtn = document.getElementById('chatSend');
  var endpoint = "{{ chat_endpoint }}";
  var history = [];
  var busy = false;

  function toggle(open){
    panel.classList.toggle('open', open);
    if (open) input.focus();
  }
  fab.addEventListener('click', function(){ toggle(!panel.classList.contains('open')); });
  document.getElementById('chatClose').addEventListener('click', function(){ toggle(false); });

  function addMsg(role, text){
    if (empty) { empty.remove(); empty = null; }
    var el = document.createElement('div');
    el.className = 'chat-msg ' + role;
    el.textContent = text;
    body.appendChild(el);
    body.scrollTop = body.scrollHeight;
    return el;
  }

  async function send(){
    var q = input.value.trim();
    if (!q || busy) return;
    busy = true;
    sendBtn.disabled = true;
    addMsg('user', q);
    input.value = '';
    var typing = addMsg('typing', '답변 작성 중…');
    try {
      var resp = await fetch(endpoint, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({question: q, history: history}),
      });
      var payload = await resp.json();
      typing.remove();
      if (!resp.ok || payload.error) {
        addMsg('err', payload.error || '답변 생성에 실패했습니다.');
      } else {
        addMsg('bot', payload.answer);
        history.push({role: 'user', content: q});
        history.push({role: 'assistant', content: payload.answer});
        if (history.length > 16) history = history.slice(-16);
      }
    } catch (e) {
      typing.remove();
      addMsg('err', '네트워크 오류로 답변을 가져오지 못했습니다.');
    } finally {
      busy = false;
      sendBtn.disabled = false;
    }
  }
  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', function(e){ if (e.key === 'Enter') send(); });
})();
</script>
{% if kakao_js_key %}
<script src="https://developers.kakao.com/sdk/js/kakao.min.js"></script>
<script>
  if (window.Kakao && !window.Kakao.isInitialized()) {
    window.Kakao.init('{{ kakao_js_key }}');
  }
</script>
{% endif %}
</body>
</html>
