<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="data:image/svg+xml,<svg%20xmlns='http%3A//www.w3.org/2000/svg'%20viewBox='0%200%2040%2040'><path%20d='M4%2021%20A16%2015%200%200%201%2036%2021%20Z'%20fill='%2310233F'/><rect%20x='9'%20y='21'%20width='4.4'%20height='6'%20rx='1.6'%20fill='%231D5BD8'/><rect%20x='17.8'%20y='21'%20width='4.4'%20height='10'%20rx='1.6'%20fill='%231D5BD8'/><rect%20x='26.6'%20y='21'%20width='4.4'%20height='14'%20rx='1.6'%20fill='%231D5BD8'/></svg>">
<title>{{ header.name }}님 보장분석 리포트</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#10233F;
  --paper:#F6F7F9;
  --card:#FFFFFF;
  --line:#E3E7EE;
  --sub:#5B6B82;
  --ok:#1D5BD8; --warn:#C77700; --gap:#C93030;
  --ok-bg:#EDF3FE; --warn-bg:#FDF3E3; --gap-bg:#FBEDED;
  --samsung:#1428A0;  --samsung-bg:#EEF0FA;
  --meritz:#E4002B;   --meritz-bg:#FCECEF;
  --hyundai:#F26F21;  --hyundai-bg:#FEF1E8;
  --mg:#0067AC;       --mg-bg:#E9F2F9;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:"Pretendard Variable",Pretendard,-apple-system,sans-serif;background:var(--paper);color:var(--ink);line-height:1.6;font-size:15px}
.page{max-width:880px;margin:0 auto;padding:48px 24px 80px}
.serif{font-family:"Noto Serif KR",serif}
.num{font-variant-numeric:tabular-nums}

header{border-bottom:3px solid var(--ink);padding-bottom:28px;margin-bottom:32px}
.eyebrow{font-size:12px;letter-spacing:.14em;color:var(--sub);text-transform:uppercase;margin-bottom:10px}
h1{font-size:34px;font-weight:700;letter-spacing:-.01em}
h1 .name{border-bottom:6px solid var(--ok-bg)}
.meta{display:flex;flex-wrap:wrap;gap:8px 28px;margin-top:16px;font-size:13.5px;color:var(--sub)}
.meta b{color:var(--ink);font-weight:600}

.brands{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}
.brand{display:inline-flex;align-items:center;gap:7px;font-size:12.5px;font-weight:600;padding:6px 13px;border-radius:99px;border:1px solid var(--line);background:var(--card)}
.dot{width:9px;height:9px;border-radius:50%;flex:none}
.dot.samsung{background:var(--samsung)} .dot.meritz{background:var(--meritz)}
.dot.hyundai{background:var(--hyundai)} .dot.mg{background:var(--mg)}

.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:44px}
.kpi{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:18px 20px}
.kpi .label{font-size:12.5px;color:var(--sub);margin-bottom:6px}
.kpi .value{font-size:24px;font-weight:700}
.kpi .unit{font-size:13px;font-weight:500;color:var(--sub);margin-left:2px}
.kpi.hl{background:var(--ink);border-color:var(--ink);color:#fff}
.kpi.hl .label,.kpi.hl .unit{color:#B9C6DB}

section{margin-bottom:52px}
h2{font-family:"Noto Serif KR",serif;font-size:21px;font-weight:700;padding-bottom:10px;border-bottom:1.5px solid var(--ink);margin-bottom:6px;display:flex;align-items:baseline;gap:10px}
h2 .no{font-size:13px;color:var(--sub);font-family:Pretendard,sans-serif;font-weight:600}
.sec-note{font-size:13px;color:var(--sub);margin-bottom:18px}

.chip{display:inline-block;font-size:11.5px;font-weight:700;padding:2px 9px;border-radius:99px;vertical-align:1px;white-space:nowrap}
.chip.ok{color:var(--ok);background:var(--ok-bg)}
.chip.warn{color:var(--warn);background:var(--warn-bg)}
.chip.gap{color:var(--gap);background:var(--gap-bg)}

.contracts{display:grid;gap:12px}
.contract{background:var(--card);border:1px solid var(--line);border-radius:12px;overflow:hidden;display:grid;grid-template-columns:1fr auto;align-items:stretch}
.contract .body{padding:16px 20px 16px 22px;position:relative}
.contract .body::before{content:"";position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--brand-color,#8A96A6)}
.co-tag{display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:800;letter-spacing:.02em;padding:3px 10px;border-radius:6px;margin-bottom:7px}
.logo{display:inline-flex;align-items:center;gap:7px;margin-bottom:8px;height:22px}
.logo .kr{font-size:12.5px;font-weight:800;letter-spacing:-.01em;color:#333}
.sym-oval{display:inline-flex;align-items:center;justify-content:center;background:var(--samsung);color:#fff;font-size:8.5px;font-weight:700;letter-spacing:.08em;font-style:italic;width:64px;height:20px;border-radius:50%}
.wordmark-meritz{color:var(--meritz);font-size:16px;font-weight:800;letter-spacing:-.03em;text-transform:lowercase;line-height:1}
.sym-hi{display:inline-flex;align-items:center;justify-content:center;background:var(--hyundai);color:#fff;font-size:11px;font-weight:800;font-style:italic;width:26px;height:20px;border-radius:5px}
.sym-mg{font-size:16px;font-weight:900;letter-spacing:-.04em;line-height:1;background:linear-gradient(115deg,var(--mg) 55%,#F5B60D 55%);-webkit-background-clip:text;background-clip:text;color:transparent}
.sym-generic{display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:10px;font-weight:800;width:26px;height:20px;border-radius:5px}
.contract .title{font-weight:700;font-size:15.5px;margin-bottom:2px}
.contract .detail{font-size:13px;color:var(--sub)}
.contract .prem{padding:16px 22px;text-align:right;font-weight:700;font-size:17px;white-space:nowrap;display:flex;flex-direction:column;justify-content:center;background:#FAFBFC;border-left:1px solid var(--line)}
.contract .prem small{font-size:11.5px;font-weight:500;color:var(--sub)}
.badge{display:inline-block;font-size:11px;font-weight:700;color:var(--warn);background:var(--warn-bg);border-radius:5px;padding:2px 8px;margin-left:6px;vertical-align:1px}
.reco-divider{display:flex;align-items:center;gap:12px;margin:22px 0 12px;font-size:12.5px;font-weight:700;color:#8A96A6;letter-spacing:.04em}
.reco-divider::before,.reco-divider::after{content:"";flex:1;border-top:1.5px dashed #C9D1DC}
.contract.reco{border:2px dashed #B7C0CC;box-shadow:none;
  background:repeating-linear-gradient(135deg,#F7F8FA 0px,#F7F8FA 9px,#EFF1F5 9px,#EFF1F5 10px)}
.contract.reco .body::before{display:none}
.contract.reco .title{color:#5B6B82}
.contract.reco .detail{color:#8A96A6}
.reco-tag{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:800;color:#fff;background:#9AA5B4;border-radius:6px;padding:3px 10px;margin-bottom:7px}
.reco-tag::before{content:"+";font-size:13px;font-weight:800;line-height:1}
.contract.reco .prem{background:transparent;border-left:1px dashed #C9D1DC;color:#8A96A6;font-size:14px}
.contract.reco .prem small{color:#A6B0BE}
.reco-why{display:inline-block;font-size:11.5px;font-weight:700;color:#75808F;background:#E8EBF0;border-radius:5px;padding:2px 8px;margin-left:6px;vertical-align:1px}

table{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--line);border-radius:10px;overflow:hidden;font-size:14px}
thead th{background:#F0F3F8;font-size:12px;font-weight:600;color:var(--sub);text-align:left;padding:9px 14px;border-bottom:1px solid var(--line)}
tbody td{padding:10px 14px;border-bottom:1px solid var(--line);vertical-align:middle}
tbody tr:last-child td{border-bottom:none}
td.r,th.r{text-align:right}
.src{display:inline-flex;gap:4px;margin-left:7px;vertical-align:1px}
.src .dot{width:8px;height:8px}
.info-note{cursor:help;color:var(--sub);font-size:11.5px;margin-left:5px;vertical-align:1px}
.gauge{position:relative;height:8px;background:#EDF0F5;border-radius:99px;min-width:110px;overflow:hidden}
.gauge .fill{position:absolute;inset:0 auto 0 0;border-radius:99px;background:var(--ok)}
.gauge .fill.warn{background:var(--warn)}
.gauge .fill.gap{background:var(--gap)}
.gauge-cell{width:140px}

.insights{display:grid;gap:12px;counter-reset:ins}
.insight{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:18px 22px 18px 58px;position:relative}
.insight::before{counter-increment:ins;content:counter(ins,decimal-leading-zero);position:absolute;left:20px;top:19px;font-size:13px;font-weight:700;color:var(--ok);font-variant-numeric:tabular-nums}
.insight b{display:block;margin-bottom:4px;font-size:15px}
.insight p{font-size:13.5px;color:var(--sub)}
.insight.urgent{border-color:#F2C9C9;background:#FFFCFC}
.insight.urgent::before{color:var(--gap)}

footer{margin-top:56px;padding-top:18px;border-top:1px solid var(--line);font-size:11.5px;color:var(--sub);line-height:1.8}
.matrix-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:10px;background:var(--card)}
.matrix{width:100%;border-collapse:collapse;font-size:12.5px;min-width:760px;border:none}
.matrix thead th{padding:8px 8px;font-size:11px;line-height:1.35;text-align:center;color:#fff;border-bottom:none;border-left:1px solid rgba(255,255,255,.25);background:var(--th-color,var(--ink))}
.matrix thead th:first-child{background:var(--ink);text-align:left;border-left:none;font-size:12px}
.matrix thead th small{display:block;font-weight:500;opacity:.85;font-size:10px}
.matrix tbody td{padding:7px 8px;text-align:right;border-left:1px solid var(--line)}
.matrix tbody td:first-child{text-align:left;font-weight:600;border-left:none;white-space:nowrap}
.matrix tbody td.empty{color:#C4CCD7}
.matrix tbody td.sum{font-weight:700;background:#F5F7FA}
.matrix tbody tr.grp td:first-child{color:var(--sub);font-size:11px;font-weight:700;background:#F0F3F8;letter-spacing:.03em}
.matrix tbody tr.grp td{background:#F0F3F8;padding:5px 8px}

@media(max-width:640px){
  .kpis{grid-template-columns:repeat(2,1fr)}
  .contract{grid-template-columns:1fr}
  .contract .prem{border-left:none;border-top:1px solid var(--line);text-align:left;flex-direction:row;gap:8px;align-items:baseline}
  .gauge-cell{width:85px}
  h1{font-size:26px}
}
@media print{
  body{background:#fff}
  .page{padding:0}
  .cover{page-break-after:always;background:#fff;border-radius:0}
  .cover-logo{font-size:14px;font-weight:700;color:#1D5BD8;margin-bottom:40px;letter-spacing:.05em}
  .cover-visual{width:100%;max-width:380px;height:320px;margin-bottom:50px;background:#fff;border-radius:20px;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(16,35,63,.12)}
  .cover-title{font-size:36px;font-weight:700;color:#10233F;margin-bottom:8px;text-align:center}
  .cover-info{font-size:13px;color:#5B6B82;margin-bottom:40px;text-align:center}
  .cover-meta{width:100%;max-width:360px;border-top:1px solid #E3E7EE;border-bottom:1px solid #E3E7EE;padding:20px 0}
  .cover-meta-row{display:flex;justify-content:space-between;padding:8px 0;font-size:13px}
  .cover-meta-row strong{color:#10233F;font-weight:600;min-width:80px}
  .cover-meta-row span{color:#5B6B82;text-align:right;flex:1}
  .section-page{page-break-after:always}
  section{page-break-inside:avoid}
}
.hero{position:relative;border-radius:16px;overflow:hidden;margin-bottom:28px;border:1px solid #F3DECB}
.hero svg{display:block;width:100%;height:auto}
.hero .caption{position:absolute;left:26px;bottom:20px;max-width:min(70%,360px);font-family:"Noto Serif KR",serif;font-size:17px;font-weight:700;color:#7A4A33;background:rgba(255,250,242,.92);padding:10px 16px;border-radius:12px;box-shadow:0 2px 10px rgba(122,74,51,.1)}
.hero .caption small{display:block;font-family:Pretendard,sans-serif;font-size:12px;font-weight:500;color:#A9765C;margin-top:3px}
@media(max-width:640px){.hero .caption{font-size:14px;left:16px;bottom:12px;padding:8px 12px;max-width:78%}}

.action-bar{position:fixed;top:22px;right:22px;z-index:40;display:flex;gap:8px}
.action-bar button{display:inline-flex;align-items:center;gap:7px;padding:11px 20px;border:none;border-radius:99px;font-family:inherit;font-size:13.5px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(16,35,63,.28);transition:transform .15s,box-shadow .15s}
.action-bar button:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(16,35,63,.34)}
.action-bar button svg{width:15px;height:15px;flex:none}
.download-btn{background:var(--ink);color:#fff}
.share-btn{background:#FEE500;color:#3C1E1E}
@media(max-width:640px){.action-bar{top:auto;bottom:18px;right:18px;flex-direction:column}.action-bar button{padding:14px}.action-bar button span{display:none}.action-bar button svg{width:18px;height:18px}}
@media print{.action-bar{display:none}}
.back-link{position:fixed;top:26px;left:22px;z-index:40;font-size:13px;font-weight:700;color:var(--sub);text-decoration:none;background:rgba(255,255,255,.85);padding:8px 14px;border-radius:99px}
@media print{.back-link{display:none}}
@media(max-width:640px){.back-link{top:16px;left:16px;font-size:12px;padding:7px 12px}}
.share-toast{position:fixed;bottom:26px;left:50%;transform:translate(-50%,12px);background:var(--ink);color:#fff;font-size:13px;font-weight:600;padding:11px 18px;border-radius:99px;z-index:60;opacity:0;pointer-events:none;transition:opacity .2s,transform .2s;box-shadow:0 6px 18px rgba(16,35,63,.3)}
.share-toast.show{opacity:1;transform:translate(-50%,0)}

.chat-fab{position:fixed;bottom:22px;left:22px;z-index:45;display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:50%;background:var(--ink);color:#fff;border:none;cursor:pointer;box-shadow:0 6px 18px rgba(16,35,63,.32);transition:transform .15s}
.chat-fab:hover{transform:translateY(-1px)}
.chat-fab svg{width:22px;height:22px}
.chat-panel{position:fixed;bottom:86px;left:22px;z-index:46;width:min(360px,calc(100vw - 44px));max-height:min(560px,calc(100vh - 140px));background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:0 12px 40px rgba(16,35,63,.22);display:flex;flex-direction:column;overflow:hidden;opacity:0;transform:translateY(12px);pointer-events:none;transition:opacity .18s,transform .18s}
.chat-panel.open{opacity:1;transform:translateY(0);pointer-events:all}
.chat-head{padding:14px 16px;border-bottom:1px solid var(--line);display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
.chat-head b{font-size:14px;display:block}
.chat-head span{font-size:11.5px;color:var(--sub)}
.chat-close{background:none;border:none;color:var(--sub);font-size:18px;cursor:pointer;line-height:1;padding:2px 4px;flex:none}
.chat-body{flex:1;overflow-y:auto;padding:14px 16px;display:flex;flex-direction:column;gap:10px;font-size:13.5px}
.chat-msg{max-width:88%;padding:9px 13px;border-radius:14px;line-height:1.55;white-space:pre-wrap}
.chat-msg.user{align-self:flex-end;background:var(--ink);color:#fff;border-bottom-right-radius:4px}
.chat-msg.bot{align-self:flex-start;background:#F0F3F8;color:var(--ink);border-bottom-left-radius:4px}
.chat-msg.err{align-self:flex-start;background:var(--gap-bg);color:var(--gap)}
.chat-msg.typing{align-self:flex-start;background:#F0F3F8;color:var(--sub);font-style:italic}
.chat-empty{color:var(--sub);font-size:12.5px;text-align:center;padding:18px 8px}
.chat-input-row{display:flex;gap:8px;padding:12px;border-top:1px solid var(--line)}
.chat-input-row input{flex:1;padding:10px 12px;border:1px solid var(--line);border-radius:99px;font-size:13.5px;font-family:inherit;background:var(--paper);color:var(--ink)}
.chat-input-row input:focus{outline:2px solid var(--ok);outline-offset:-1px}
.chat-input-row button{padding:0 16px;border:none;border-radius:99px;background:var(--ok);color:#fff;font-weight:700;font-size:13px;cursor:pointer}
.chat-input-row button:disabled{opacity:.4;cursor:not-allowed}
@media(max-width:640px){.chat-panel{left:12px;bottom:78px;width:calc(100vw - 24px)}.chat-fab{left:16px;bottom:16px}}
@media print{.chat-fab,.chat-panel{display:none}}
</style>
</head>
<body>
{% if not is_public_view %}<a class="back-link" href="/reports">← 저장된 리포트</a>{% endif %}
<div class="action-bar">
  {% if not is_public_view %}
  <button class="share-btn" type="button" id="shareBtn" data-report-id="{{ report_id }}" data-title="{{ header.name }}님 보장분석 리포트" data-url="{{ share_url or '' }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="10.5" x2="15.4" y2="6.5"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/></svg>
    <span>카카오톡으로 보내기</span>
  </button>
  {% endif %}
  <button class="download-btn" type="button" onclick="downloadReport()">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 10l5 5 5-5"/><path d="M5 21h14"/></svg>
    <span>리포트 다운로드</span>
  </button>
</div>
<div class="share-toast" id="shareToast"></div>
{% if chat_enabled %}
<button class="chat-fab" type="button" id="chatFab" title="리포트에 대해 질문하기">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
</button>
<div class="chat-panel" id="chatPanel">
  <div class="chat-head">
    <div><b>리포트 챗봇</b><span>{{ header.name }}님 리포트 내용을 근거로 답변해요</span></div>
    <button class="chat-close" type="button" id="chatClose">✕</button>
  </div>
  <div class="chat-body" id="chatBody">
    <div class="chat-empty" id="chatEmpty">예: "실비 보장이 충분한가요?", "가장 시급한 보완은 뭐예요?"</div>
  </div>
  <div class="chat-input-row">
    <input type="text" id="chatInput" placeholder="리포트에 대해 질문해보세요" maxlength="500">
    <button type="button" id="chatSend">전송</button>
  </div>
</div>
{% endif %}
<div class="page">

<!-- 첫번째 페이지: 표지 -->
<div class="cover" style="position:relative;padding:60px 48px;min-height:100vh;display:flex;flex-direction:column;justify-content:space-between;align-items:flex-start">
  <!-- Toss Insurance 로고 (우측 상단) -->
  <div style="position:absolute;top:48px;right:48px;font-size:13px;font-weight:700;color:#1D5BD8;letter-spacing:.05em;display:flex;align-items:center;gap:6px">
    <svg viewBox="0 0 24 24" width="20" height="20" style="fill:#1D5BD8">
      <circle cx="12" cy="12" r="10" fill="currentColor"/>
    </svg>
    <span>toss insurance</span>
  </div>

  <!-- 메인 콘텐츠 -->
  <div style="flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;width:100%">
    <!-- 가족/블록 일러스트 -->
    <svg viewBox="0 0 380 280" xmlns="http://www.w3.org/2000/svg" style="width:280px;height:220px;margin-bottom:40px">
      <defs>
        <linearGradient id="hand-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#F5D4C0"/><stop offset="1" stop-color="#E8BCA8"/>
        </linearGradient>
      </defs>
      <!-- 손 -->
      <ellipse cx="80" cy="200" rx="35" ry="45" fill="url(#hand-grad)"/>
      <path d="M 50 180 Q 45 150 55 130" stroke="#D9A890" stroke-width="3" fill="none" stroke-linecap="round"/>
      <path d="M 70 170 Q 68 135 75 110" stroke="#D9A890" stroke-width="3" fill="none" stroke-linecap="round"/>
      <path d="M 90 175 Q 92 140 100 115" stroke="#D9A890" stroke-width="3" fill="none" stroke-linecap="round"/>
      <path d="M 110 185 Q 115 155 120 130" stroke="#D9A890" stroke-width="3" fill="none" stroke-linecap="round"/>
      <!-- 나무 블록 -->
      <g>
        <!-- 아래층 -->
