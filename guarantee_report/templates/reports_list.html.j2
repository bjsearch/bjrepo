<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="data:image/svg+xml,<svg%20xmlns='http%3A//www.w3.org/2000/svg'%20viewBox='0%200%2040%2040'><path%20d='M4%2021%20A16%2015%200%200%201%2036%2021%20Z'%20fill='%2310233F'/><rect%20x='9'%20y='21'%20width='4.4'%20height='6'%20rx='1.6'%20fill='%231D5BD8'/><rect%20x='17.8'%20y='21'%20width='4.4'%20height='10'%20rx='1.6'%20fill='%231D5BD8'/><rect%20x='26.6'%20y='21'%20width='4.4'%20height='14'%20rx='1.6'%20fill='%231D5BD8'/></svg>">
<title>저장된 보장분석 리포트</title>
<style>
  :root{--ink:#10233F;--paper:#F6F7F9;--card:#FFFFFF;--line:#E3E7EE;--sub:#5B6B82;--ok:#1D5BD8;--warn:#C77700;--gap:#C93030;--ok-bg:#EDF3FE;--warn-bg:#FDF3E3;--gap-bg:#FBEDED}
  *{box-sizing:border-box}
  body{font-family:-apple-system,"Pretendard",sans-serif;background:var(--paper);color:var(--ink);margin:0;padding:40px 20px 80px;line-height:1.6}
  .wrap{max-width:920px;margin:0 auto}
  .top{display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:6px}
  h1{font-size:24px;margin:0}
  a.new{font-size:13.5px;font-weight:700;color:var(--ok);text-decoration:none}
  p.sub{color:var(--sub);font-size:14px;margin:6px 0 26px}
  table{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--line);border-radius:10px;overflow:hidden;font-size:13.5px}
  thead th{background:#F0F3F8;font-size:12px;font-weight:600;color:var(--sub);text-align:left;padding:10px 12px;border-bottom:1px solid var(--line)}
  tbody td{padding:11px 12px;border-bottom:1px solid var(--line);vertical-align:middle}
  tbody tr:last-child td{border-bottom:none}
  tbody tr:hover{background:#FAFBFC}
  td.r{text-align:right}
  .name-link{font-weight:700;color:var(--ink);text-decoration:none}
  .name-link:hover{text-decoration:underline}
  .chip{display:inline-block;font-size:11px;font-weight:700;padding:2px 8px;border-radius:99px;white-space:nowrap}
  .chip.ok{color:var(--ok);background:var(--ok-bg)}
  .chip.warn{color:var(--warn);background:var(--warn-bg)}
  .chip.gap{color:var(--gap);background:var(--gap-bg)}
  .chips{display:flex;gap:4px;flex-wrap:wrap}
  .del{background:none;border:none;color:var(--sub);font-size:12px;cursor:pointer;padding:4px 6px}
  .del:hover{color:var(--gap)}
  .actions{margin-top:20px;display:flex;align-items:center;gap:12px}
  button.compare{padding:11px 22px;border:none;border-radius:8px;background:var(--ink);color:#fff;font-size:14px;font-weight:700;cursor:pointer}
  button.compare:disabled{opacity:.35;cursor:not-allowed}
  .hint3{font-size:12.5px;color:var(--sub)}
  .empty{padding:60px 20px;text-align:center;color:var(--sub);font-size:14px}
  .navbar{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:8px 14px;margin-bottom:14px;font-size:13px;color:var(--sub)}
  .navbar .brand-group{display:flex;align-items:center;gap:9px}
  .navbar .brand{display:flex;align-items:center;gap:7px;text-decoration:none;flex:none}
  .navbar .brand .wordmark{font-family:"Noto Serif KR",serif;font-weight:700;font-size:15.5px;color:var(--ink);letter-spacing:-.01em}
  .navbar .menu{display:flex;flex-wrap:wrap;align-items:center;gap:6px 16px}
  .navbar a,.navbar .who{white-space:nowrap}
  .navbar a{display:inline-flex;align-items:center;gap:5px;color:var(--sub);text-decoration:none;font-weight:600}
  .navbar a:hover{color:var(--ink)}
  .navbar a.admin{color:var(--ok)}
  .navbar a.admin:hover{color:var(--ink)}
  .navbar a svg{width:14px;height:14px;flex:none}
</style>
</head>
<body>
<div class="wrap">
  <div class="navbar">
    <div class="brand-group">
      <a class="brand" href="/">
        <svg viewBox="0 0 40 40" width="22" height="22" aria-hidden="true"><path d="M4 21 A16 15 0 0 1 36 21 Z" fill="#10233F"/><rect x="9" y="21" width="4.4" height="6" rx="1.6" fill="#1D5BD8"/><rect x="17.8" y="21" width="4.4" height="10" rx="1.6" fill="#1D5BD8"/><rect x="26.6" y="21" width="4.4" height="14" rx="1.6" fill="#1D5BD8"/></svg>
        <span class="wordmark">보장분석</span>
      </a>
    </div>
    <div class="menu">
      <span class="who">{{ user.name }}님{% if user.role == 'admin' %} · 관리자{% endif %}</span>
      {% if user.role == 'admin' %}<a class="admin" href="/admin"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>관리자 화면</a>{% endif %}
      <a href="/logout"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>로그아웃</a>
    </div>
  </div>
  <div class="top">
    <h1>저장된 보장분석 리포트</h1>
    <a class="new" href="/">+ 새 리포트 생성</a>
  </div>
  <p class="sub">체크박스로 2건 이상 선택하면 같은 체크리스트 기준으로 나란히 비교할 수 있습니다.</p>

  {% if reports %}
  <form action="/compare" method="get" id="cmpForm">
    <table>
      <thead>
        <tr>
          <th></th>
          <th>고객</th>
          {% if user.role == 'admin' %}<th>생성자</th>{% endif %}
          <th>생성일</th>
          <th class="r">월 보험료</th>
          <th>진단 결과</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for r in reports %}
        <tr>
          <td><input type="checkbox" name="ids" value="{{ r.id }}" class="cb"></td>
          <td><a class="name-link" href="/reports/{{ r.id }}">{{ r.customer_name }}</a></td>
          {% if user.role == 'admin' %}<td>{{ r.created_by_name or '-' }}</td>{% endif %}
          <td>{{ r.created_at[:10] }}</td>
          <td class="r">{{ "{:,}".format(r.monthly_premium) if r.monthly_premium else '-' }}원</td>
          <td>
            <div class="chips">
              <span class="chip ok">적정 {{ r.ok_count }}</span>
              <span class="chip warn">주의·부족 {{ r.warn_count }}</span>
              <span class="chip gap">미가입 {{ r.gap_count }}</span>
            </div>
          </td>
          <td>
            <form action="/reports/{{ r.id }}/delete" method="post" onsubmit="return confirm('{{ r.customer_name }}님 리포트를 삭제할까요?')">
              <button type="submit" class="del">삭제</button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <div class="actions">
      <button type="submit" class="compare" id="cmpBtn" disabled>선택한 항목 비교하기</button>
      <span class="hint3" id="cmpHint">2건 이상 선택하세요</span>
    </div>
  </form>
  {% else %}
  <div class="empty">아직 저장된 리포트가 없습니다. <a href="/">여기서 새 리포트를 생성</a>하면 자동으로 저장됩니다.</div>
  {% endif %}
</div>
<script>
  const boxes = document.querySelectorAll('.cb');
  const btn = document.getElementById('cmpBtn');
  const hint = document.getElementById('cmpHint');
  function update(){
    const n = document.querySelectorAll('.cb:checked').length;
    btn.disabled = n < 2;
    hint.textContent = n < 2 ? '2건 이상 선택하세요' : n + '건 선택됨';
  }
  boxes.forEach(b => b.addEventListener('change', update));
</script>
</body>
</html>
