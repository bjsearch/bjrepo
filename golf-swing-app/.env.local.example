ANTHROPIC_API_KEY=your_anthropic_api_key_here
SESSION_SECRET=replace_with_a_long_random_string

# Optional: choose the default AI provider used when the user doesn't override
# it from the UI. 'anthropic' (default) or 'gemini'.
AI_PROVIDER=anthropic

# Required only when using Gemini (AI_PROVIDER=gemini or selected from the UI).
# Get a key at https://aistudio.google.com/ -> "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: default Gemini model when the user doesn't pick one from the UI.
# e.g. gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
